APP_NAME=Student Support Recommendation API
APP_ENV=local

# Gemini analysis
# Leave empty to use deterministic local fallback without calling Gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MAX_RETRIES=0
ALLOW_LOCAL_FALLBACK=true

# RAG search
USE_GEMINI_EMBEDDINGS=false
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
RAG_TOP_K=100
RAG_MIN_RECOMMENDATION_SCORE=0.18
RAG_DATA_FILES=integrated_institution_data.csv,transformed_scholarships_detailed_dgst.csv,welfare_integrated_data.csv

# Optional: used only by app/fetch_api.py when refreshing welfare API data.
NATIONAL_API_KEY=
LOCAL_API_KEY=
